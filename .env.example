# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI (OpenAI) ────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Python AI service on Fly.io ────────────────────────────────────────────
# AI_SERVICE_URL: base URL Netlify functions call (no trailing slash).
# INTERNAL_SECRET: shared secret Netlify ↔ Python service. Sent as
#   X-Internal-Token on every request from Netlify functions to Python.
AI_SERVICE_URL=https://python-ai.fly.dev
INTERNAL_SECRET=

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ─── PayPal ─────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_PLAN_ID=
PAYPAL_API_BASE=https://api-m.paypal.com
# Required by /api/paypal-webhook. Get this from PayPal Developer Dashboard
# after registering the webhook URL (https://<domain>/api/paypal-webhook).
PAYPAL_WEBHOOK_ID=

# ─── App ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://minallo.de

# ─── Rate limits (optional, defaults shown) ─────────────────────────────────
AI_ASK_RATE_LIMIT_MAX=30
AI_ASK_RATE_LIMIT_WINDOW_MS=3600000
AI_GENERATE_RATE_LIMIT_MAX=30
AI_GENERATE_RATE_LIMIT_WINDOW_MS=3600000
NOTES_RATE_LIMIT_MAX=15
NOTES_RATE_LIMIT_WINDOW_MS=3600000
WRITING_COACH_RATE_LIMIT_MAX=20
WRITING_COACH_RATE_LIMIT_WINDOW_MS=3600000
AI_CHAT_RATE_LIMIT_MAX=30
AI_CHAT_RATE_LIMIT_WINDOW_MS=3600000

# Monthly fair-use caps (per user, reset 1st of each calendar month UTC).
# Two independent buckets — must match the values in the AGB.
#   INTERACTIVE_MONTHLY_CAP: chat / RAG / writing-coach / streaming asks
#   GENERATION_MONTHLY_CAP:  quiz / flashcards / notes summaries
INTERACTIVE_MONTHLY_CAP=2000
GENERATION_MONTHLY_CAP=200
# Legacy alias (kept for back-compat; routes to the interactive bucket).
AI_MONTHLY_CAP=2000

# ─── Schreibtrainer persistence (Python service, off until migrations land) ─
WRITING_COACH_PERSISTENCE_ENABLED=false
