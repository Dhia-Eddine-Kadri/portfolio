# Copy this file to .env for local dev. Never commit .env.
# Production secrets live in Fly.io (or whichever host) — not in this file.

# --- Supabase (same project as Netlify; same secret as backend)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# --- OpenAI
OPENAI_API_KEY=sk-replace-me
OPENAI_GENERATE_MODEL=gpt-4o-mini
OPENAI_GENERATE_MODEL_STRONG=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536

# --- Vision OCR indexing
# Off by default because indexing may call a vision model once per weak page.
# Enable this in production to benefit from scanned/diagram/formula/handwriting OCR.
MINALLO_VISION_OCR_ENABLED=false
MINALLO_VISION_OCR_MODEL=gpt-4o-mini
MINALLO_VISION_OCR_MAX_PAGES=20
MINALLO_VISION_OCR_DPI=150
MINALLO_VISION_OCR_HANDWRITING_DPI=220
MINALLO_HANDWRITING_OCR_ENABLED=true

# Optional formula-heavy OCR provider. Requires both credentials and routing.
MATHPIX_APP_ID=
MATHPIX_APP_KEY=
MINALLO_MATHPIX_ROUTING=off

# --- Shared secret between Netlify and this service.
# Reuses the existing Netlify env var that the trigger-processing flow
# already uses, so there's only one internal secret to rotate.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Paste the SAME value here that Netlify has under INTERNAL_SECRET.
INTERNAL_SECRET=replace-with-long-random-string

# --- Misc
LOG_LEVEL=INFO
ENVIRONMENT=development
