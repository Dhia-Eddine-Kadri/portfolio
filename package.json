{
  "name": "minallo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint": "eslint frontend/js",
    "lint:fix": "eslint --fix frontend/js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "tsx --test --test-reporter=spec \"tests/backend/validation.test.mjs\" \"tests/backend/env.test.mjs\" \"tests/backend/stripe-webhook.test.mjs\" \"tests/backend/create-checkout.test.mjs\" \"tests/backend/payment-flow.test.mjs\" \"tests/backend/admin-stats.test.mjs\" \"tests/frontend/escape-html.test.mjs\" \"tests/frontend/auth-storage-contract.test.mjs\" \"tests/frontend/ai-input-render.test.mjs\"",
    "typecheck": "tsc -p backend/tsconfig.json && tsc -p frontend/tsconfig.json && tsc -p functions/tsconfig.json",
    "typecheck:backend": "tsc -p backend/tsconfig.json",
    "typecheck:frontend": "tsc -p frontend/tsconfig.json",
    "typecheck:pages": "tsc -p functions/tsconfig.json",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "build:frontend": "tsc -p frontend/tsconfig.build.json",
    "build": "npm run build:frontend && node scripts/build-production.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report tests/e2e/report",
    "dev": "wrangler pages dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.6.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "wrangler": "^4.86.0"
  },
  "dependencies": {},
  "prettier": {
    "singleQuote": true,
    "semi": true,
    "tabWidth": 2,
    "trailingComma": "none",
    "printWidth": 100
  }
}
