{
  "name": "minallo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint": "eslint backend/functions backend/lib frontend/js",
    "lint:fix": "eslint --fix backend/functions backend/lib frontend/js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "tsx --test --test-reporter=spec \"tests/backend/validation.test.mjs\" \"tests/backend/env.test.mjs\" \"tests/backend/stripe-webhook.test.mjs\" \"tests/backend/create-checkout.test.mjs\" \"tests/frontend/escape-html.test.mjs\"",
    "typecheck": "tsc -p backend/tsconfig.json && tsc -p frontend/tsconfig.json",
    "typecheck:backend": "tsc -p backend/tsconfig.json",
    "typecheck:frontend": "tsc -p frontend/tsconfig.json",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "build:frontend": "tsc -p frontend/tsconfig.build.json",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report tests/e2e/report",
    "dev": "netlify dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.6.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "dependencies": {}
}
